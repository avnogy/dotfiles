backend = "glx";

shadow = false;

fading = true;
fade-in-step = 0.12;
fade-out-step = 0.12;
fade-delta = 5;

inactive-opacity = 1.0;
active-opacity = 1.0;
frame-opacity = 1.0;

vsync = true;

use-damage = false;

unredir-if-possible = true;

blur-method = "none";

corner-radius = 0;

detect-rounded-corners = false;
detect-client-opacity = true;
detect-transient = true;
detect-client-leader = true;

mark-wmwin-focused = true;
mark-ovredir-focused = true;

glx-no-stencil = true;
glx-copy-from-front = false;

xrender-sync-fence = true;

{{- if eq .chezmoi.hostname "eclipse" }}
glx-no-rebind-pixmap = true;
{{- end }}

{{- if eq .chezmoi.hostname "nomad" }}
use-damage = true;
{{- end }}

blur:
{
  method = "dual_kawase";
  strength = 1;
};

opacity-rule = [
  "90:class_g = 'Alacritty'"
];
